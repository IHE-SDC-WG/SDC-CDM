    VISIT_OCCURRENCE ||--o{ DEVICE_EXPOSURE : "visit_occurrence_id"
    VISIT_DETAIL ||--o{ DEVICE_EXPOSURE : "visit_detail_id"
    PROVIDER ||--o{ DEVICE_EXPOSURE : "provider_id"
    CONCEPT ||--o{ DEVICE_EXPOSURE : "device/type concepts"

    PERSON ||--o{ MEASUREMENT : "person_id"
    VISIT_OCCURRENCE ||--o{ MEASUREMENT : "visit_occurrence_id"
    VISIT_DETAIL ||--o{ MEASUREMENT : "visit_detail_id"
    PROVIDER ||--o{ MEASUREMENT : "provider_id"
    CONCEPT ||--o{ MEASUREMENT : "measurement/type/unit/value concepts"

    PERSON ||--o{ OBSERVATION : "person_id"
    VISIT_OCCURRENCE ||--o{ OBSERVATION : "visit_occurrence_id"
    VISIT_DETAIL ||--o{ OBSERVATION : "visit_detail_id"
    PROVIDER ||--o{ OBSERVATION : "provider_id"
    CONCEPT ||--o{ OBSERVATION : "observation/type/unit/qualifier concepts"

    PERSON ||--o{ SPECIMEN : "person_id"
    CONCEPT ||--o{ SPECIMEN : "specimen/type/unit/site/disease concepts"

    PERSON ||--o{ NOTE : "person_id"
    VISIT_OCCURRENCE ||--o{ NOTE : "visit_occurrence_id"
